# Copy to ".env" to provide values non-interactively.
#   cp .env.example .env && $EDITOR .env
# .env is git-ignored and never committed.

# Git identity (used by modules/70-git.sh)
GIT_NAME="Your Name"
GIT_EMAIL="you@example.com"

# Optional: authorise an SSH public key on Linux without a prompt
# (used by modules/75-ssh.sh). Paste your PUBLIC key only.
# SSH_PUBLIC_KEY="ssh-ed25519 AAAA... you@laptop"

# Optional bootstrap overrides (used by install.sh)
# DOTFILES_REPO="https://github.com/raminr77/zero-day.git"
# DOTFILES_DIR="$HOME/.zero-day"
# DOTFILES_BRANCH="main"
